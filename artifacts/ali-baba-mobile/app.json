{
  "expo": {
    "name": "АЛИ-БАБА И 40 КЛАДОВ",
    "slug": "ali-baba-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ali-baba-mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1426"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alibaba.fortytreausres"
    },
    "android": {
      "package": "com.alibaba.fortytreasures",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0B1426"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "bez1655",
    "extra": {
      "eas": {
        "projectId": "bd8d37ef-b99b-4fe8-97d9-fcd15b969f56"
      }
    }
  }
}
